generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  relationMode = "foreignKeys"
}

model Tenant {
  id        String       @id @default(uuid()) @db.Uuid
  subdomain String       @unique
  name      String
  logoUrl   String?
  status    TenantStatus @default(ACTIVE)
  plan      Plan         @default(FREE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?

  users         User[]
  emailVerifications EmailVerification[]
  subjects      Subject[]
  landingPages  LandingPage[]
  liveSessions  LiveSession[]
  subscriptions Subscription[]
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  email          String
  passwordHash   String
  name           String?
  role           Role     @default(STUDENT)
  chargilyId     String?
  emailVerifiedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  progress     VideoProgress[]
  subscriptions Subscription[]
  emailVerifications EmailVerification[]

  @@unique([email, tenantId], name: "email_tenantId")
  @@index([tenantId])
  @@index([tenantId, emailVerifiedAt])
}

model EmailVerification {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @db.Uuid
  userId     String    @db.Uuid
  email      String
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, email])
  @@index([tenantId, userId])
  @@index([tenantId, consumedAt, expiresAt])
}

model Subject {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  title    String
  color    String @default("#3B82F6")
  sortOrder Int   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  stages Stage[]

  @@index([tenantId, deletedAt])
}

model Stage {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @db.Uuid
  subjectId String  @db.Uuid
  title     String
  sortOrder Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  subject Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([tenantId, subjectId, deletedAt])
}

model Lesson {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @db.Uuid
  stageId     String  @db.Uuid
  title       String
  description String?
  videoUid    String?
  sortOrder   Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  stage    Stage           @relation(fields: [stageId], references: [id], onDelete: Cascade)
  progress VideoProgress[]

  @@index([tenantId, stageId, deletedAt])
}

model VideoProgress {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  userId         String   @db.Uuid
  lessonId       String   @db.Uuid
  secondsWatched Int      @default(0)
  isCompleted    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  lesson Lesson @relation(fields: [lessonId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, lessonId], name: "userId_lessonId")
  @@index([tenantId, userId, deletedAt])
}

model Subscription {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @db.Uuid
  userId           String    @db.Uuid
  chargilyId       String?
  status           SubStatus @default(ACTIVE)
  plan             Plan      @default(FREE)
  currentPeriodEnd DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  user   User   @relation(fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, deletedAt])
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

model LandingPage {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @db.Uuid
  blocks    Json
  published Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, deletedAt])
}

model LiveSession {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  title         String
  zoomMeetingId String
  zoomJoinUrl   String?
  zoomPassword  String?
  scheduledAt   DateTime
  isLive        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, deletedAt])
}
